{
  "name": "finance-split",
  "version": "1.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npm run typecheck && vite build && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json && cp server/schema.sql server-dist/schema.sql && mkdir -p server-dist/migrations && cp server/migrations/*.sql server-dist/migrations/",
    "start": "NODE_ENV=production node server-dist/index.js",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "db:migrate:production": "NODE_ENV=production node server-dist/scripts/migrate.js",
    "db:seed": "tsx server/scripts/seed.ts",
    "test": "node --test --experimental-strip-types server/*.test.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.server.json",
    "lint": "npm run lint:eslint && npm run lint:styles",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:styles": "stylelint \"client/src/**/*.{css,vue}\"",
    "lint:fix": "npm run lint:eslint -- --fix && npm run lint:styles -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run lint && npm run format:check && npm run test && npm run build"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^8.0.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "mysql2": "^3.14.0",
    "papaparse": "^5.5.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/express-mysql-session": "^3.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^24.0.0",
    "@types/papaparse": "^5.3.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "postcss-html": "^1.8.1",
    "prettier": "3.9.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.0.0",
    "vue-tsc": "^3.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
