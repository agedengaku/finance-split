{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "server",
    "outDir": "server-dist",
    "sourceMap": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["server/**/*.ts"],
  "exclude": ["server/**/*.test.ts"]
}
